{
	"name": "agent-task-manager-mcp",
	"version": "1.0.0",
	"description": "MCP server for managing long-running agent tasks with MongoDB, SQLite, or JSON file storage",
	"main": "dist/index.js",
	"bin": {
		"agent-task-manager-mcp": "./dist/index.js"
	},
	"files": [
		"dist",
		"LICENSE.md"
	],
	"keywords": [
		"mcp",
		"agent",
		"task-manager",
		"mongodb",
		"sqlite",
		"json"
	],
	"license": "SEE LICENSE IN LICENSE.md",
	"engines": {
		"node": ">=18"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/mlnima/agent-task-manager-mcp"
	},
	"scripts": {
		"build": "tsc",
		"dev": "tsx src/index.ts",
		"start": "node dist/index.js",
		"start:http": "node dist/index.js --http",
		"start:https": "node dist/index.js --https",
		"test": "tsx tests/run-all.ts",
		"test:storage": "tsx tests/test-storage.ts",
		"test:mcp": "tsx tests/test-mcp-tools.ts"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.0.0",
		"better-sqlite3": "^11.6.0",
		"dotenv": "^16.4.5",
		"pg": "^8.13.0",
		"express": "^5.2.1",
		"mongoose": "^8.5.0",
		"selfsigned": "^5.0.0",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@types/better-sqlite3": "^7.6.11",
		"@types/pg": "^8.11.10",
		"@types/express": "^5.0.0",
		"@types/node": "^22.0.0",
		"tsx": "^4.16.0",
		"typescript": "^5.5.0"
	}
}
