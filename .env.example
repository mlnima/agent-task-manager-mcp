# ─── Storage Backend ─────────────────────────────────────────────────────
# mongodb | postgres | sqlite | json (default: mongodb)
STORAGE=mongodb

# ─── MongoDB (required when STORAGE=mongodb) ─────────────────────────────
MONGODB_URI=mongodb://localhost:27017/agent-tasks

# ─── PostgreSQL (when STORAGE=postgres) ───────────────────────────────────
# Use POSTGRES_URL or DATABASE_URL. Schema auto-created on first connect.
# POSTGRES_URL=postgresql://user:password@localhost:5432/agent_tasks
# DATABASE_URL=postgresql://user:password@localhost:5432/agent_tasks

# ─── SQLite (when STORAGE=sqlite) ─────────────────────────────────────────
# Default: ./data/agent-tasks.db
# SQLITE_PATH=./data/agent-tasks.db

# ─── JSON file (when STORAGE=json) ───────────────────────────────────────
# Default: ./data/agent-tasks.json. Single-agent only.
# JSON_STORAGE_PATH=./data/agent-tasks.json

# ─── HTTP/HTTPS (optional) ───────────────────────────────────────────────
# MCP_ALLOWED_HOSTS=myapp.ngrok.io,custom.local
